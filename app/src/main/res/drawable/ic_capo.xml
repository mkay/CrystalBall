<!--
  The capo, drawn as Material Symbols "add_row_above": a bar clamped across the top of the box,
  which is what a capo is. Not in compose material-icons-extended, so it ships as a drawable.
  Material Symbols author their paths in a 960-unit grid whose origin sits at the *top* of a y-up
  box (viewBox "0 -960 960 960"), hence the group translate: it moves the path back down into
  Android's y-down viewport.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="960"
    android:viewportHeight="960">
    <!-- Left white: Compose's Icon tints the whole vector to the colour the row asks for. -->
    <group android:translateY="960">
        <path
            android:fillColor="@android:color/white"
            android:pathData="M200,-160h560v-240H200v240Zm640,80H120v-720h160v80h-80v240h560v-240h-80v-80h160v720ZM480,-480Zm0,80v-80 80Zm0,0Zm-40,-240v-80h-80v-80h80v-80h80v80h80v80h-80v80h-80Z" />
    </group>
</vector>
